@using ChampionsLeague.ViewModels
@model IEnumerable<OrderVM>

<h2>Your History</h2>

@if (Model.Count() == 0) {
    <div class="alert alert-info">Your history is empty.</div>
} else {

<div class="container">
    <div class="row">

        @foreach (var order in Model)
        {
            <div class="col-md-4 mb-4"
                 data-search="@($"{order.OrderDate}"))">
                <div>
                        <!-- OrderLines -->
                        @if (order.OrderLines != null && order.OrderLines.Any())
                        {
                            <hr />
                            <h6>Orderlines:</h6>

                        @for (int i = 0; i < order.OrderLines.Count; i++)
                        {
                            var line = order.OrderLines[i];
                            var max = line.productVM.Type == "Ticket" ? 4 : 1;

                            <tr class="cart-line" data-line="@line.LineId">
                                <td>@line.productVM.Name</td>

                                <td>
                                    <input type="number"
                                           class="form-control quantity-input"
                                           value="@line.Quantity"
                                           min="1"
                                           max="@max"
                                           data-line="@line.LineId"
                                           data-price="@line.productVM.DynamicUnitPrice" />
                                </td>

                                <td>@line.productVM.DynamicUnitPrice €</td>

                                <td class="line-total">
                                    @(line.Quantity* line.productVM.DynamicUnitPrice) €
                                </td>

                                <td>
                                    <select class="form-select section-select"
                                            data-line="@line.LineId"
                                            data-product="@line.productVM.ProductId">
                                        <option>Loading...</option>
                                    </select>
                                </td>

                                <td>
                                    <form asp-action="RemoveFromCart" method="post" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="lineId" value="@line.LineId" />
                                        <button type="submit" class="btn btn-danger btn-sm">Remove</button>
                                    </form>
                                </td>
                            </tr>
                        }
                        }
                        <div class="product-card-actions">
                    </div>

                </div>

            </div>
        }
    </div>
</div>

}