@using ChampionsLeague.ViewModels
@model IEnumerable<OrderVM>

<h2>Your History</h2>

@if (Model.Count() == 0) {
    <div class="alert alert-info">Your history is empty.</div>
} else {
    <section id="OrderList">
        <h2>Order List</h2>
        @foreach (var order in Model)
        {
        <div class="col-md-6 mb-6")>
            <h2>Order overview</h2> <br />
            <b>order date : @order.OrderDate</b>
            <hr />
            <h6>Orderlines:</h6>
            <ul>
                @foreach (OrderLineVM line in order.OrderLines)
                {
                        <li>@line.Quantity x @line.productVM.Name unitprice: @line.StaticUnitPrice <br /> line-total: @(line.Quantity* line.productVM.DynamicUnitPrice)</li>
                    <br />
                }
                </ul>
                </div>

        }
    </section>
    <hr />
    <section id="seatAssignments">
        <article class="col-md-6">
            <h2>Ticket seats</h2>
        </article>
        <article class="col-md-6">
            <h2>Subscription seats</h2>
            <table id="ticketSeatTable">
            
            </table>
        </article>
    </section>
}