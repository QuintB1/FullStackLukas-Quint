@using ChampionsLeague.ViewModels
@model IEnumerable<OrderVM>

<h2>Your History</h2>

@if (Model.Count() == 0) {
    <div class="alert alert-info">Your history is empty.</div>
} else {

<div class="container">
    <div class="row">

        @foreach (var order in Model)
        {
            <div class="col-md-6 mb-6"data-search="@($"{order.OrderDate}"))">
                <div>
                            <hr />
                            <h6>Orderlines:</h6>
                            <ul>
                            @foreach(OrderLineVM line in order.OrderLines){
                                <li>@line.Quantity x @line.productVM.Name unitprice: @line.StaticUnitPrice</li> <br />
                            }
                            </ul>

        
                </div>

            </div>
        }
    </div>
</div>

}