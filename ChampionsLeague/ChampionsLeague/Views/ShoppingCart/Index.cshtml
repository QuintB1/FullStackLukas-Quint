@using ChampionsLeague.ViewModels
@model OrderVM

<h2>Your Shopping Cart</h2>

@if (Model == null)
{
    <div class="alert alert-info">
        Your shopping cart is empty.
    </div>
}
else
{
    <p>Order Date: @Model.OrderDate</p>

    @if (Model.OrderLines == null || !Model.OrderLines.Any())
    {
        <div class="alert alert-warning">
            Your cart contains no items.
        </div>
    }
    else
    {
        <table class="table table-bordered">
            <thead>
                <tr>
                    <th>LineNumber</th>
                    <th>Product</th>
                    <th>Quantity</th>
                    <th>Price</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var line in Model.OrderLines)
                {
                    <tr>
                        <td>@line.LineId</td>
                        <td>@line.ProductId</td>
                        <td>@line.Quantity</td>
                        <td>@line.StaticUnitPrice</td>
                    </tr>
                }
            </tbody>
        </table>
    }
}
