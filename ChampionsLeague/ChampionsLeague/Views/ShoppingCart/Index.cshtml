@using ChampionsLeague.ViewModels
@model OrderVM

<h2>Your Shopping Cart</h2>

@if (Model == null)
{
    <div class="alert alert-info">Your shopping cart is empty.</div>
    <a asp-controller="ShoppingCart"
       asp-action="History"
       class="btn btn-secondary">
        View Purchase History
    </a>

}
else
{
    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Product</th>
                <th>Qty</th>
                <th>Price</th>
                <th>Total</th>
                <th>Section</th>
                <th>Remove</th>
            </tr>
        </thead>

        <tbody>
            @for (int i = 0; i < Model.OrderLines.Count; i++)
            {
                var line = Model.OrderLines[i];
                var max = line.productVM.Type == "Ticket" ? 4 : 1;

                <tr class="cart-line" data-line="@line.LineId">
                    <td>@line.productVM.Name</td>

                    <td>
                        <input type="number"
                               class="form-control quantity-input"
                               value="@line.Quantity"
                               min="1"
                               max="@max"
                               data-line="@line.LineId"
                               data-price="@line.productVM.DynamicUnitPrice" />
                    </td>

                    <td>€ @line.productVM.DynamicUnitPrice</td>

                    <td class="line-total">
                        € @(line.Quantity* line.productVM.DynamicUnitPrice)
                    </td>

                    <td>
                        <select class="form-select section-select"
                                data-line="@line.LineId"
                                data-product="@line.productVM.ProductId" required>
                            <option>Loading...</option>
                        </select>
                        <div class="invalid-feedback">
                            Please select a section.
                        </div>

                    </td>

                    <td>
                        <form asp-action="RemoveFromCart" method="post" style="display:inline;">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="lineId" value="@line.LineId" />
                            <button type="submit" class="btn btn-danger btn-sm">Remove</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <form asp-action="CheckOut" method="post" id="checkoutForm">
        @Html.AntiForgeryToken()
        <input type="hidden" id="CartJson" name="CartJson" />
        <h3>Total: <span id="cart-total"></span> €</h3>
        <button type="submit" class="btn btn-primary">Checkout</button>
    </form>
    <a asp-controller="ShoppingCart"
       asp-action="History"
       class="btn btn-secondary">
        View Purchase History
    </a>


    <script>
        // -----------------------------
        // 1. Build cart object safely
        // -----------------------------
        let cart = {
            orderId: @Model.OrderId,
            orderLines: [
                @for (int i = 0; i < Model.OrderLines.Count; i++)
                {
                        var line = Model.OrderLines[i];
                        var sectionId = line.StadiumSectionId ?? 0;

                        <text>
                        {
                            lineId: @line.LineId,
                            quantity: @line.Quantity,
                            stadiumSectionId: @sectionId
                        }@(i < Model.OrderLines.Count - 1 ? "," : "")
                        </text>
                }
            ]
        };

        // -----------------------------
        // 2. Update totals
        // -----------------------------
        function updateTotals() {
            let cartTotal = 0;

            document.querySelectorAll(".cart-line").forEach(row => {
                const qtyInput = row.querySelector(".quantity-input");
                const lineTotalCell = row.querySelector(".line-total");

                const price = parseFloat(qtyInput.dataset.price);
                const qty = parseInt(qtyInput.value);

                const lineTotal = price * qty;
                lineTotalCell.textContent = lineTotal.toFixed(2) + " €";

                cartTotal += lineTotal;
            });

            document.getElementById("cart-total").textContent = cartTotal.toFixed(2);
        }

        // -----------------------------
        // 3. Load stadium sections
        // -----------------------------
        document.querySelectorAll(".section-select").forEach(select => {
            const productId = select.dataset.product;
            const lineId = select.dataset.line;

            fetch(`/ShoppingCart/GetSectionsForProduct?productId=${productId}`)
                .then(r => r.json())
                .then(sections => {
                    select.innerHTML = `<option value="">-- Select section --</option>`;

                    sections.forEach(sec => {
                        const opt = document.createElement("option");
                        opt.value = sec.sectionId;
                        opt.textContent = `${sec.name} (Cap: ${sec.capacity})`;

                        const line = cart.orderLines.find(l => l.lineId == lineId);
                        if (line && line.stadiumSectionId == sec.sectionId)
                            opt.selected = true;

                        select.appendChild(opt);
                    });
                });
        });

        // -----------------------------
        // 4. Quantity change handler
        // -----------------------------
        document.querySelectorAll(".quantity-input").forEach(input => {
            input.addEventListener("input", function () {
                const lineId = this.dataset.line;
                const qty = parseInt(this.value);

                const line = cart.orderLines.find(l => l.lineId == lineId);
                line.quantity = qty;

                updateTotals();
            });
        });

        // -----------------------------
        // 5. Section change handler
        // -----------------------------
        document.querySelectorAll(".section-select").forEach(select => {
            select.addEventListener("change", function () {
                const lineId = this.dataset.line;
                const sectionId = parseInt(this.value);

                const line = cart.orderLines.find(l => l.lineId == lineId);
                line.stadiumSectionId = sectionId;
            });
        });

        // -----------------------------
        // 6. Before submitting: serialize cart
        // -----------------------------
                document.getElementById("checkoutForm").addEventListener("submit", function (e) {

            // Validate all section selects
            const selects = document.querySelectorAll(".section-select");
            let allValid = true;

            selects.forEach(sel => {
                if (!sel.value || sel.value.trim() === "") {
                    allValid = false;
                    sel.classList.add("is-invalid");
                } else {
                    sel.classList.remove("is-invalid");
                }
            });

            if (!allValid) {
                e.preventDefault();
                alert("please select sections for all products");
                return;
            }

            // Serialize cart
            try {
                const json = JSON.stringify(cart);
                document.getElementById("CartJson").value = json;
            } catch (err) {
                console.error("Failed to serialize cart", err);
                e.preventDefault();
                alert("Cart could not be processed.");
            }
        });

    </script>
}
