@using ChampionsLeague.ViewModels
@model MatchVM

@{
    ViewData["Title"] = "Match Details";
}

<h2>Match Details</h2>

<div class="card">
    <div class="card-body">
        <h4 class="card-title">Match @Model.Id</h4>

        <dl class="row">
            <dt class="col-sm-3">Datum</dt>
            <dd class="col-sm-9">@Model.DateTime.ToString("dd/MM/yyyy HH:mm")</dd>

            <dt class="col-sm-3">Thuisploeg</dt>
            <dd class="col-sm-9">@Model.HomeClubName</dd>

            <dt class="col-sm-3">Uitploeg</dt>
            <dd class="col-sm-9">@Model.AwayClubName</dd>

            <dt class="col-sm-3">Stadion ID</dt>
            <dd class="col-sm-9">@Model.StadiumId</dd>
        </dl>

        <a asp-action="Index" class="btn btn-secondary">Terug</a>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Bewerken</a>
    </div>
</div>