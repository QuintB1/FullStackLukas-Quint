@model IEnumerable<ChampionsLeague.ViewModels.MatchVM>

<table class="table">
    <thead>
        <tr>
            <th>Date</th>
            <th>Match</th>
            <th>Stadium</th>
            <th>Add ticket</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var match in Model)
        {
            <tr>
                <td>@match.DateTime</td>
                <td>@match.HomeClubName vs @match.AwayClubName</td>
                <td>@match.Name</td>
                <td>
                    <a asp-controller="Match"
                       asp-action="AddTicketToCart"
                       asp-route-matchId="@match.Id"
                       class="btn btn-primary btn-sm">
                        Add Ticket
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>
