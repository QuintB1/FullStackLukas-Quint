@model IEnumerable<ChampionsLeague.ViewModels.MatchVM>

<table class="table">
    <thead>
        <tr>
            <th>Date</th>
            <th>Match</th>
            <th>Stadium</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var match in Model)
        {
            <tr>
                <td>@match.DateTime</td>
                <td>@match.HomeClubName vs @match.AwayClubName</td>
                <td>@match.StadiumId</td>
            </tr>
        }
    </tbody>
</table>