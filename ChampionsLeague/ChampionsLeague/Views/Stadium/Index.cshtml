@model IEnumerable<ChampionsLeague.ViewModels.HomeclubStadiumSelectVM>

<h1>Select a Stadium</h1>

<select id="clubSelect" class="form-select">
    <option value="">-- Select a club --</option>
    @foreach (var item in Model)
    {
        <option value="@item.HomeStadiumId" data-club="@item.ClubId">
            @item.Name
        </option>
    }
</select>

<button id="addSubscriptionBtn" class="btn btn-primary btn-sm" disabled>
    Add subscription to cart
</button>

<hr />

<div id="stadiumContainer" style="display:none;">
    <h2 id="stadiumName"></h2>
    <p id="stadiumAddress"></p>

    <h3>Sections</h3>
    <table class="table table-bordered" id="sectionsTable">
        <thead>
            <tr>
                <th>Section</th>
                <th>Capacity</th>
            </tr>
        </thead>
        <tbody></tbody>
    </table>
</div>

<div id="noStadiumMessage" style="display:none; color:red;">
    No stadium found for this club.
</div>

@section Scripts {
    <script>
        let selectedClubId = null;

        $("#clubSelect").on("change", function () {

            const stadiumId = $(this).val();
            selectedClubId = $(this).find(":selected").data("club");

            // Enable button only if a valid club is selected
            $("#addSubscriptionBtn").prop("disabled", !selectedClubId);

            // Reset UI
            $("#stadiumContainer").hide();
            $("#noStadiumMessage").hide();
            $("#sectionsTable tbody").empty();

            if (!stadiumId) return;

            // Load stadium info
            $.ajax({
                url: "/Stadium/GetStadium",
                type: "GET",
                data: { stadiumId: stadiumId },
                success: function (data) {

                    if (!data) {
                        $("#noStadiumMessage").show();
                        return;
                    }

                    $("#stadiumName").text(data.name);
                    $("#stadiumAddress").text(data.address);

                    data.sections.forEach(section => {
                        $("#sectionsTable tbody").append(`
                            <tr>
                                <td>${section.name}</td>
                                <td>${section.capacity}</td>
                            </tr>
                        `);
                    });

                    $("#stadiumContainer").show();
                },
                error: function () {
                    $("#noStadiumMessage").show();
                }
            });
        });

        // Add subscription to cart
        $("#addSubscriptionBtn").on("click", function () {
            if (!selectedClubId) return;

            window.location.href =
                `/Stadium/AddSubscriptionToCart?clubId=${selectedClubId}`;
        });
    </script>
}
